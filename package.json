{
  "name": "animesh",
  "private": true,
  "license": "GPL-3.0-only",
  "version": "0.4.0",
  "description": "A high-performance desktop anime streaming and downloading client built with Tauri v2, featuring magnet link aggregation search, BitTorrent stream playback, and embedded MKV subtitle extraction and rendering.",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:web": "vite --mode web",
    "build": "tsc && vite build",
    "build:web": "tsc && vite build --mode web",
    "preview": "vite preview",
    "tauri": "tauri",
    "tauri:android:apk": "tauri android build --apk --target aarch64",
    "test": "vitest run",
    "test:rust": "cargo test --manifest-path src-tauri/Cargo.toml -p animesh_core -- --test-threads=1",
    "test:rust:coverage": "cargo llvm-cov --manifest-path src-tauri/Cargo.toml -p animesh_core --fail-under-lines 90 --fail-under-functions 90 --ignore-filename-regex \"torrent_manager|src/subtitles\\.rs|infrastructure\" --no-clean -- --test-threads=1",
    "check:apply": "biome check --write --no-errors-on-unmatched",
    "check:error-handling": "tsx scripts/check-error-handling.ts",
    "check:application-params": "tsx scripts/check-application-params.ts",
    "check:interface-methods": "tsx scripts/check-interface-methods.ts",
    "check:presentation-tauri-imports": "tsx scripts/check-presentation-tauri-imports.ts",
    "check:function-length": "tsx scripts/check-function-length.ts",
    "typecheck": "tsc --noEmit",
    "test:coverage": "vitest run --coverage",
    "bump-version": "tsx scripts/bump-version.ts"
  },
  "dependencies": {
    "@fontsource-variable/geist": "^5.2.9",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-log": "^2",
    "@tauri-apps/plugin-notification": "^2",
    "@tauri-apps/plugin-opener": "^2",
    "@tauri-apps/plugin-store": "^2",
    "@tauri-apps/plugin-window-state": "^2",
    "ajanuw-context": "^1.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.21.0",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.6.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-router-dom": "^7.18.0",
    "shadcn": "^4.11.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.0",
    "@tailwindcss/vite": "^4.3.1",
    "@tauri-apps/cli": "^2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^26.0.0",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitest/coverage-v8": "^4.1.9",
    "autoprefixer": "^10.5.0",
    "happy-dom": "^20.10.6",
    "lefthook": "^2.1.9",
    "oxc-parser": "^0.137.0",
    "postcss": "^8.5.15",
    "tailwindcss": "^4.3.1",
    "tsx": "^4.22.4",
    "typescript": "~7.0.2",
    "vite": "^8.0.16",
    "vitest": "^4.1.9"
  },
  "packageManager": "pnpm@11.12.0+sha512.820a6fbd0d9f04c226638002aead1e45340a9139dd5dc077c1d83ef44aa2481c8eb6637b4c9aa696a3c7e35ba818e49cf27213e5f2b91138d09b7a3e26e898ba"
}
